root@53ff2df4de8c:/# ls /data
root@53ff2df4de8c:/# echo "Hello Docker"> /data/test.txt
root@53ff2df4de8c:/# cat /data/test.txt
Hello Docker
root@53ff2df4de8c:/# exit
exit
